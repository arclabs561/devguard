# devguard Configuration Example
# Copy to .env and fill in values

# GitHub - for Dependabot alerts
GITHUB_TOKEN=
GITHUB_ORG=your-org
GITHUB_REPOS_TO_MONITOR=your-org/repo1,your-org/repo2

# Vercel - for deployment status
VERCEL_TOKEN=
VERCEL_PROJECTS_TO_MONITOR=

# Fly.io - for app health
FLY_API_TOKEN=
FLY_APPS_TO_MONITOR=

# Domain/SSL monitoring
DOMAINS_TO_MONITOR=example.com,app.example.com

# Tailscale expected nodes
TAILSCALE_EXPECTED_NODES=

# Docker Swarm
SWARM_EXPECTED_NODES=
SWARM_CRITICAL_SERVICES=

# AWS
AWS_ALLOWED_INSTANCES=

# OpenRouter (for project_flaudit sweep: files-to-prompt + LLM flaw analysis)
OPENROUTER_API_KEY=

# Security testing
REDTEAM_ENABLED=false

# Environment
ENVIRONMENT=development
