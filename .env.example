# Guardian Configuration Example
# Copy to .env and fill in values

# GitHub - for Dependabot alerts
GITHUB_TOKEN=ghp_xxxx
GITHUB_ORG=arclabs561
GITHUB_REPOS_TO_MONITOR=arclabs561/runctl,arclabs561/ai-visual-test

# Vercel - for deployment status
VERCEL_TOKEN=
VERCEL_PROJECTS_TO_MONITOR=

# Fly.io - for app health
FLY_API_TOKEN=
FLY_APPS_TO_MONITOR=trackweave

# API usage monitoring
FIRECRAWL_API_KEY=
TAVILY_API_KEY=

# Security testing
REDTEAM_ENABLED=false

# Environment
ENVIRONMENT=development
